# --- SaaS & Control Plane ---
PORT=4000
NODE_ENV=development
OPSPILOT_MODE=development
JWT_SECRET=super_secret_jwt_signing_key_change_me
CLIENT_URL=http://localhost:3000
NEXT_PUBLIC_CONTROL_API_URL=http://localhost:4000

# --- Internal Services & Portable Runtime Paths ---
SANDBOX_CONTROLLER_URL=http://localhost:4010
GRAPH_WORKER_URL=http://localhost:4004
DISCOVERY_WORKER_URL=http://localhost:4002
OPSPILOT_TEMP_ROOT=
OPSPILOT_SNAPSHOT_STORAGE_ROOT=
SANDBOX_REPOSITORY_SUBDIRECTORY=
SANDBOX_NODE_IMAGE=node:20-bookworm-slim
SANDBOX_COMMAND_TIMEOUT_MS=600000
SANDBOX_MAX_LOG_BYTES=1048576
SANDBOX_MEMORY_LIMIT=1g
SANDBOX_CPU_LIMIT=1
SANDBOX_PID_LIMIT=256

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/opspilot?schema=public

# --- Redis & Queues ---
REDIS_URL=redis://localhost:6379/0

# --- Object Storage ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=opspilot-snapshots

# --- LLM Provider Keys ---
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# --- GitHub Integration ---
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Telemetry & Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# --- Integration Providers ---
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
GETSTREAM_API_KEY=
GETSTREAM_API_SECRET=
